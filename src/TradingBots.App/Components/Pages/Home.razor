@page "/"
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@inject UiLoadingState Loading
@inject ClientAuthSession Auth
@implements IDisposable

<PageTitle>Dashboard</PageTitle>
<h1 class="tb-page-title">Dashboard</h1>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-warning" role="alert">
        @_errorMessage
    </div>
}

@if (_summary is null)
{
    <p>Cargando...</p>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card"><div class="card-body"><h6>Bots</h6><h3>@_summary.TotalBots</h3></div></div>
        </div>
        <div class="col-md-3">
            <div class="card"><div class="card-body"><h6>Activos</h6><h3>@_summary.RunningBots</h3></div></div>
        </div>
        <div class="col-md-3">
            <div class="card"><div class="card-body"><h6>Budget total</h6><h3>@_summary.TotalBudget.ToString("0.00") USDT</h3></div></div>
        </div>
        <div class="col-md-3">
            <div class="card"><div class="card-body"><h6>PnL total</h6><h3 class="@PnlClass(_summary.TotalPnl)">@_summary.TotalPnl.ToString("0.00") USDT</h3></div></div>
        </div>
    </div>
    <div class="alert alert-info">
        <strong>Auto-creator:</strong> @_summary.LastAutoTraderStatus
        <span class="ms-2">(@(_summary.LastAutoTraderRunUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "sin fecha"))</span>
    </div>
    <div class="mb-3">
        <span class="badge @ExecutionBadgeClass(_summary)">
            @ExecutionBadgeText(_summary)
        </span>
    </div>

    <div class="card mb-4 border-secondary">
        <div class="card-header d-flex flex-wrap align-items-center justify-content-between gap-2">
            <span>KPIs de operaciones</span>
            <div class="d-flex flex-wrap gap-1">
                <button type="button" class="btn btn-sm btn-outline-light" @onclick="PresetToday">Hoy (UTC)</button>
                <button type="button" class="btn btn-sm btn-outline-light" @onclick="PresetYesterday">Ayer (UTC)</button>
                <button type="button" class="btn btn-sm btn-outline-light" @onclick="PresetLast7Days">Últimos 7 días</button>
                <button type="button" class="btn btn-sm btn-outline-light" @onclick="PresetLast30Days">Últimos 30 días</button>
            </div>
        </div>
        <div class="card-body">
            <p class="small text-muted mb-3">
                Filtra por <strong>día único</strong> (misma fecha inicio y fin) o por <strong>rango</strong>. Las fechas se interpretan en <strong>UTC</strong> (medianoche a medianoche), igual que <code>ExecutedAtUtc</code> en base de datos.
            </p>
            <div class="row g-2 align-items-end mb-3">
                <div class="col-sm-auto">
                    <label class="form-label mb-0">Desde</label>
                    <input class="form-control" type="date" @bind="_kpiDateFrom" />
                </div>
                <div class="col-sm-auto">
                    <label class="form-label mb-0">Hasta</label>
                    <input class="form-control" type="date" @bind="_kpiDateTo" />
                </div>
                <div class="col-sm-auto">
                    <button type="button" class="btn btn-primary" disabled="@_kpiLoading" @onclick="ApplyKpiRange">
                        @if (_kpiLoading)
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                        }
                        else
                        {
                            <span>Aplicar</span>
                        }
                    </button>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(_kpiError))
            {
                <div class="alert alert-warning py-2">@_kpiError</div>
            }
            else if (!Auth.SessionHydrated)
            {
                <p class="small text-muted mb-0">Comprobando sesión…</p>
            }
            else if (_kpis is not null)
            {
                <div class="row g-3 mb-3">
                    <div class="col-6 col-md-4 col-lg-2">
                        <div class="tb-kpi-tile">
                            <div class="tb-kpi-label">Operaciones</div>
                            <div class="tb-kpi-value">@_kpis.TotalTrades</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg-2">
                        <div class="tb-kpi-tile">
                            <div class="tb-kpi-label">Compras / Ventas</div>
                            <div class="tb-kpi-value small">@_kpis.BuyCount / @_kpis.SellCount</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg-2">
                        <div class="tb-kpi-tile">
                            <div class="tb-kpi-label">PnL realizado</div>
                            <div class="tb-kpi-value @PnlClass(_kpis.TotalRealizedPnlUsdt)">@_kpis.TotalRealizedPnlUsdt.ToString("0.00")</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg-2">
                        <div class="tb-kpi-tile">
                            <div class="tb-kpi-label">Volumen (≈ quote)</div>
                            <div class="tb-kpi-value">@_kpis.GrossVolumeQuoteUsdt.ToString("0.00")</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg-2">
                        <div class="tb-kpi-tile">
                            <div class="tb-kpi-label">Ventas ganadoras / perdedoras</div>
                            <div class="tb-kpi-value small">@_kpis.WinningSells / @_kpis.LosingSells</div>
                            @if (_kpis.WinningSells + _kpis.LosingSells > 0)
                            {
                                <div class="tb-kpi-sub text-muted">Win rate ventas: @FormatWinRate(_kpis)</div>
                            }
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg-2">
                        <div class="tb-kpi-tile">
                            <div class="tb-kpi-label">Mejor / peor trade</div>
                            <div class="tb-kpi-value small @PnlClass(_kpis.BestTradePnlUsdt)">@_kpis.BestTradePnlUsdt.ToString("0.00")</div>
                            <div class="tb-kpi-value small @PnlClass(_kpis.WorstTradePnlUsdt)">@_kpis.WorstTradePnlUsdt.ToString("0.00")</div>
                        </div>
                    </div>
                </div>
                <p class="small text-muted mb-2">
                    Rango UTC: @FormatUtc(_kpis.RangeFromUtc) → antes de @FormatUtc(_kpis.RangeToUtcExclusive)
                </p>
                @if (_kpis.ByBot.Count > 0)
                {
                    <h6 class="mt-3">Por bot</h6>
                    <table class="table table-sm table-striped mb-0">
                        <thead>
                            <tr><th>Bot</th><th>Ops</th><th>PnL realizado</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _kpis.ByBot)
                            {
                                <tr>
                                    <td>@row.BotName</td>
                                    <td>@row.Trades</td>
                                    <td class="@PnlClass(row.RealizedPnlUsdt)">@row.RealizedPnlUsdt.ToString("0.00") USDT</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
        </div>
    </div>

    <h4>Mercado</h4>
    <table class="table table-sm table-striped">
        <thead>
            <tr><th>Par</th><th>Precio</th><th>24h</th></tr>
        </thead>
        <tbody>
            @foreach (var ticker in _summary.Market)
            {
                <tr>
                    <td>@ticker.Symbol</td>
                    <td>@ticker.LastPrice.ToString("0.########")</td>
                    <td class="@PnlClass(ticker.PriceChangePercent24h)">@ticker.PriceChangePercent24h.ToString("0.00")%</td>
                </tr>
            }
        </tbody>
    </table>

    <h4 class="mt-4">Sugerencias del bot analista</h4>
    <table class="table table-sm table-striped">
        <thead>
            <tr><th>Par</th><th>Señal</th><th>Estrategia sugerida</th><th>Score</th><th>24h</th><th>Motivo</th></tr>
        </thead>
        <tbody>
            @foreach (var suggestion in _summary.Suggestions)
            {
                <tr>
                    <td>@suggestion.Symbol</td>
                    <td class="@SignalClass(suggestion.Signal)">@suggestion.Signal</td>
                    <td><span class="badge bg-secondary">@suggestion.SuggestedStrategy</span></td>
                    <td>@suggestion.Score.ToString("0.0000")</td>
                    <td class="@PnlClass(suggestion.PriceChangePercent24h)">@suggestion.PriceChangePercent24h.ToString("0.00")%</td>
                    <td>@suggestion.Rationale</td>
                </tr>
            }
        </tbody>
    </table>

    <h4 class="mt-4">Profit/Perdida por bot</h4>
    <table class="table table-sm table-striped">
        <thead>
            <tr><th>Bot</th><th>Hoy</th><th>Acumulado</th></tr>
        </thead>
        <tbody>
            @foreach (var p in _summary.BotPerformance)
            {
                <tr>
                    <td>@p.BotName</td>
                    <td class="@PnlClass(p.DailyPnlUsdt)">@p.DailyPnlUsdt.ToString("0.00") USDT</td>
                    <td class="@PnlClass(p.TotalPnlUsdt)">@p.TotalPnlUsdt.ToString("0.00") USDT</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private DashboardSummary? _summary;
    private TradeKpisSummary? _kpis;
    private string _errorMessage = string.Empty;
    private string _kpiError = string.Empty;
    private bool _kpiLoading;
    private DateTime _kpiDateFrom = DateTime.UtcNow.Date;
    private DateTime _kpiDateTo = DateTime.UtcNow.Date;

    protected override async Task OnInitializedAsync()
    {
        Auth.SessionChanged += OnAuthChanged;
        await Task.WhenAll(LoadSummaryAsync(), LoadKpisAsync());
    }

    private void OnAuthChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadKpisAsync();
            StateHasChanged();
        });
    }

    public void Dispose() => Auth.SessionChanged -= OnAuthChanged;

    private async Task LoadSummaryAsync()
    {
        Loading.Begin();
        try
        {
            var client = HttpFactory.CreateClient();
            client.BaseAddress = new Uri(Nav.BaseUri);
            using var response = await client.GetAsync("/api/dashboard/summary");
            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = $"No se pudo cargar el dashboard (HTTP {(int)response.StatusCode}).";
                return;
            }

            _summary = await response.Content.ReadFromJsonAsync<DashboardSummary>();
            if (_summary is null)
            {
                _errorMessage = "El dashboard devolvio una respuesta vacia.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error cargando dashboard: {ex.Message}";
        }
        finally
        {
            Loading.End();
        }
    }

    private async Task ApplyKpiRange() => await LoadKpisAsync();

    private async Task PresetToday()
    {
        var u = DateTime.UtcNow.Date;
        _kpiDateFrom = u;
        _kpiDateTo = u;
        await LoadKpisAsync();
    }

    private async Task PresetYesterday()
    {
        var u = DateTime.UtcNow.Date.AddDays(-1);
        _kpiDateFrom = u;
        _kpiDateTo = u;
        await LoadKpisAsync();
    }

    private async Task PresetLast7Days()
    {
        var to = DateTime.UtcNow.Date;
        _kpiDateFrom = to.AddDays(-6);
        _kpiDateTo = to;
        await LoadKpisAsync();
    }

    private async Task PresetLast30Days()
    {
        var to = DateTime.UtcNow.Date;
        _kpiDateFrom = to.AddDays(-29);
        _kpiDateTo = to;
        await LoadKpisAsync();
    }

    private static string FormatUtc(DateTime utc) =>
        utc.Kind == DateTimeKind.Utc
            ? utc.ToString("yyyy-MM-dd HH:mm'Z'", CultureInfo.InvariantCulture)
            : DateTime.SpecifyKind(utc, DateTimeKind.Utc).ToString("yyyy-MM-dd HH:mm'Z'", CultureInfo.InvariantCulture);

    private async Task LoadKpisAsync()
    {
        _kpiLoading = true;
        _kpiError = string.Empty;
        if (!Auth.SessionHydrated)
        {
            _kpis = null;
            _kpiLoading = false;
            return;
        }

        if (!Auth.IsAuthenticated)
        {
            _kpis = null;
            _kpiError = "Inicia sesión para ver KPIs de operaciones y volúmenes.";
            _kpiLoading = false;
            return;
        }

        Loading.Begin();
        try
        {
            var fromStr = _kpiDateFrom.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
            var toStr = _kpiDateTo.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
            var client = HttpFactory.CreateClient();
            client.BaseAddress = new Uri(Nav.BaseUri);
            Auth.ApplyBearer(client);
            var url = $"/api/dashboard/trade-kpis?dateFrom={Uri.EscapeDataString(fromStr)}&dateTo={Uri.EscapeDataString(toStr)}";
            using var response = await client.GetAsync(url);
            if (!response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadAsStringAsync();
                _kpis = null;
                _kpiError = $"No se pudieron cargar los KPIs (HTTP {(int)response.StatusCode}). {body}";
                return;
            }

            _kpis = await response.Content.ReadFromJsonAsync<TradeKpisSummary>();
        }
        catch (Exception ex)
        {
            _kpis = null;
            _kpiError = $"Error: {ex.Message}";
        }
        finally
        {
            _kpiLoading = false;
            Loading.End();
        }
    }

    private static string FormatWinRate(TradeKpisSummary k)
    {
        var d = k.WinningSells + k.LosingSells;
        if (d <= 0)
        {
            return "—";
        }

        return $"{100m * k.WinningSells / d:0.0}%";
    }

    private static string PnlClass(decimal value) => value >= 0 ? "text-success" : "text-danger";
    private static string SignalClass(string signal) => signal == "BUY" ? "text-success fw-bold" : "text-warning";
    private static string ExecutionBadgeClass(DashboardSummary summary) =>
        summary.RealTradingEnabled ? "bg-danger" : "bg-secondary";
    private static string ExecutionBadgeText(DashboardSummary summary)
    {
        if (summary.RealTradingEnabled)
        {
            return $"LIVE-{summary.ExchangeEnvironment}";
        }

        return $"PAPER-{summary.ExchangeEnvironment}";
    }
}
