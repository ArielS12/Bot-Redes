@page "/bots/{BotId:guid}"
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@inject UiLoadingState Loading
@inject ClientAuthSession Auth
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>Detalle de bot</PageTitle>

@if (_loadingDetail)
{
    <p>Cargando detalle...</p>
}
else if (_bot is null)
{
    <div class="alert @(_detailIsError ? "alert-danger" : "alert-secondary")" role="alert">
        @if (string.IsNullOrWhiteSpace(_detailMessage))
        {
            <span>No se pudo cargar el bot.</span>
        }
        else
        {
            @_detailMessage
        }
    </div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(_detailMessage))
    {
        <div class="alert @(_detailIsError ? "alert-danger" : "alert-success")" role="alert">@_detailMessage</div>
    }
    <h1 class="tb-page-title">@_bot.Name</h1>
    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <div class="card"><div class="card-body"><h6>Estado</h6><h5>@_bot.State</h5></div></div>
        </div>
        <div class="col-md-3">
            <div class="card"><div class="card-body"><h6>Estrategia</h6><h5>@_bot.StrategyType</h5></div></div>
        </div>
        <div class="col-md-3">
            <div class="card"><div class="card-body"><h6>Budget</h6><h5>@_bot.BudgetUsdt.ToString("0.00") USDT</h5></div></div>
        </div>
        <div class="col-md-3">
            <div class="card"><div class="card-body"><h6>PnL total</h6><h5 class="@PnlClass(_bot.RealizedPnlUsdt + _bot.UnrealizedPnlUsdt)">@(_bot.RealizedPnlUsdt + _bot.UnrealizedPnlUsdt).ToString("0.00") USDT</h5></div></div>
        </div>
    </div>
    @if (_bot.PositionQuantity > 0m)
    {
        <div class="mb-3 d-flex flex-wrap align-items-center gap-2">
            <span class="text-muted">Posición abierta:</span>
            <span class="badge bg-secondary">@_bot.PositionQuantity.ToString("0.########") @(_bot.PositionSymbol)</span>
            @if (Auth.IsAuthenticated)
            {
                <button type="button" class="btn btn-sm btn-warning" @onclick="ForceSellAsync">Forzar venta (mercado)</button>
            }
            else
            {
                <span class="text-muted small"><a href="/login">Inicia sesión</a> para forzar venta.</span>
            }
        </div>
    }

    <h4>Compras / Ventas</h4>
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Par</th>
                <th>Side</th>
                <th>Precio</th>
                <th>Cantidad</th>
                <th>PnL realizado</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var trade in _trades)
            {
                <tr>
                    <td>@trade.ExecutedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@trade.Symbol</td>
                    <td class="@(trade.Side == "BUY" ? "text-primary" : "text-warning")">@trade.Side</td>
                    <td>@trade.Price.ToString("0.########")</td>
                    <td>@trade.Quantity.ToString("0.########")</td>
                    <td class="@PnlClass(trade.RealizedPnlUsdt)">@trade.RealizedPnlUsdt.ToString("0.00")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter] public Guid BotId { get; set; }

    private TradingBot? _bot;
    private readonly List<TradeExecution> _trades = [];
    private string _detailMessage = string.Empty;
    private bool _detailIsError;
    private bool _loadingDetail = true;

    protected override async Task OnInitializedAsync()
    {
        Auth.SessionChanged += OnAuthChanged;
        await ReloadAsync();
    }

    private void OnAuthChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await ReloadAsync();
            StateHasChanged();
        });
    }

    public void Dispose() => Auth.SessionChanged -= OnAuthChanged;

    private async Task ReloadAsync()
    {
        _loadingDetail = true;
        _detailMessage = string.Empty;
        _detailIsError = false;
        Loading.Begin();
        try
        {
            if (!Auth.SessionHydrated)
            {
                _bot = null;
                _trades.Clear();
                _detailMessage = "Comprobando sesión…";
                return;
            }

            if (!Auth.IsAuthenticated)
            {
                _bot = null;
                _trades.Clear();
                _detailMessage = "Inicia sesión para ver el detalle y el historial de trades.";
                return;
            }

            var client = HttpFactory.CreateClient();
            client.BaseAddress = new Uri(Nav.BaseUri);
            Auth.ApplyBearer(client);
            _bot = await client.GetFromJsonAsync<TradingBot>($"/api/bots/{BotId}");
            var trades = await client.GetFromJsonAsync<List<TradeExecution>>($"/api/bots/{BotId}/trades");
            _trades.Clear();
            if (trades is not null)
            {
                _trades.AddRange(trades);
            }

            if (_bot is null)
            {
                _detailMessage = "No se encontró el bot.";
                _detailIsError = true;
            }
        }
        finally
        {
            _loadingDetail = false;
            Loading.End();
        }
    }

    private async Task ForceSellAsync()
    {
        if (_bot is null || !Auth.IsAuthenticated)
        {
            return;
        }

        var sym = !string.IsNullOrWhiteSpace(_bot.PositionSymbol)
            ? _bot.PositionSymbol
            : (_bot.Symbols.FirstOrDefault() ?? "?");
        var confirmText =
            $"¿Vender toda la posición a mercado?\nBot: {_bot.Name}\nCantidad: {_bot.PositionQuantity:0.########} {sym}.";
        if (!await JSRuntime.InvokeAsync<bool>("tbConfirm", confirmText))
        {
            return;
        }

        Loading.Begin();
        try
        {
            var client = HttpFactory.CreateClient();
            client.BaseAddress = new Uri(Nav.BaseUri);
            Auth.ApplyBearer(client);
            var response = await client.PostAsync($"/api/bots/{BotId}/force-sell", content: null);
            var result = await response.Content.ReadFromJsonAsync<ForceSellResponse>();
            if (result is null || result.Outcome != "ok")
            {
                _detailIsError = true;
                _detailMessage = result?.Message ?? $"Error (HTTP {(int)response.StatusCode}).";
                return;
            }

            _detailIsError = false;
            _detailMessage = result.Message;
            await ReloadAsync();
        }
        finally
        {
            Loading.End();
        }
    }

    private static string PnlClass(decimal value) => value >= 0 ? "text-success" : "text-danger";
}
